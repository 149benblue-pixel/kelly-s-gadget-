{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Premium e-commerce gadget product available in the store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "integer" },
        "originalPrice": { "type": "integer" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "stock": { "type": "integer" },
        "ratingCount": { "type": "integer" },
        "ratingAverage": { "type": "number" },
        "featured": { "type": "boolean" },
        "newArrival": { "type": "boolean" },
        "bestSeller": { "type": "boolean" },
        "specs": { "type": "object" }
      },
      "required": ["id", "name", "price", "category", "imageUrl", "stock"]
    },
    "Category": {
      "title": "Category",
      "description": "Category item grouping similar gadgets together",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["id", "name", "slug"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order containing detailed gadgets purchased",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderNumber": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "paymentDetails": { "type": "object" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "orderNumber", "userEmail", "items", "totalAmount", "status"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "E-commerce promotional coupon code data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "type": { "type": "string" },
        "value": { "type": "number" },
        "usageLimit": { "type": "integer" },
        "usageCount": { "type": "integer" },
        "active": { "type": "boolean" }
      },
      "required": ["id", "code", "type", "value", "active"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Storefront global website configuration options",
      "type": "object",
      "properties": {
        "storeName": { "type": "string" },
        "currency": { "type": "string" },
        "taxRate": { "type": "integer" },
        "shippingFee": { "type": "integer" },
        "mpesaPaybill": { "type": "string" },
        "paypalEmail": { "type": "string" },
        "bankDetails": { "type": "string" },
        "contactEmail": { "type": "string" },
        "contactPhone": { "type": "string" },
        "contactAddress": { "type": "string" }
      }
    },
    "Customer": {
      "title": "Customer",
      "description": "Registered customer storefront credentials and profile parameters",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "password": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["id", "name", "email"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Catalog of commercial items"
    },
    "categories": {
      "schema": "Category",
      "description": "Item categorization groupings"
    },
    "orders": {
      "schema": "Order",
      "description": "Logged e-commerce purchases"
    },
    "coupons": {
      "schema": "Coupon",
      "description": "Promotional discounts list"
    },
    "settings": {
      "schema": "Settings",
      "description": "Global storefront configurations"
    },
    "customers": {
      "schema": "Customer",
      "description": "Standard client consumer registry records"
    }
  }
}
