rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Catch-all safety net (default deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Products collection: publicly viewable, editable by storefront admin or manager
    match /products/{productId} {
      allow read: if true;
      allow write: if true;
    }

    // Categories collection
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if true;
    }

    // Orders collection: clients can create/track orders
    match /orders/{orderId} {
      allow read: if true;
      allow write: if true;
    }

    // Coupons collection
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if true;
    }

    // Settings collection
    match /settings/{settingsId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
